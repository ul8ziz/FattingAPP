<UserControl x:Class="Ul8ziz.FittingApp.App.Views.ConnectDevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,16,24,24">
            
            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Connect Devices" 
                           Style="{StaticResource Heading1Style}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Select programmer and hearing aid devices to connect" 
                           Style="{StaticResource CaptionStyle}"/>
            </StackPanel>
            
            <!-- Status Banner: No Programmer Selected / Programmer Selected / Connected -->
            <Border Margin="0,0,0,24">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource StatusBannerInfoStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="BorderBrush" Value="#FECACA"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                <Setter Property="Background" Value="#D1FAE5"/>
                                <Setter Property="BorderBrush" Value="#A7F3D0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Width="24" Height="24"
                            Background="#3B82F6"
                            CornerRadius="12"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                        <Setter Property="Background" Value="#F59E0B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                        <Setter Property="Background" Value="#EF4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="!"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="!"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                            <Setter Property="Text" Value="✕"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Text" Value="✓"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    
                    <!-- Message -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1E40AF"
                                   Margin="0,0,0,2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="No Programmer Selected"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Text" Value="Searching for Programmers..."/>
                                            <Setter Property="Foreground" Value="#92400E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                            <Setter Property="Text" Value="No Programmers Found"/>
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Text" Value="Programmer Found"/>
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontSize="13"
                                   Foreground="#1E40AF"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Scan and select a programmer to begin"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Text" Value="Please wait while we search for connected programmers"/>
                                            <Setter Property="Foreground" Value="#92400E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                            <Setter Property="Text" Value="{Binding FoundProgrammersMessage}"/>
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Text" Value="{Binding FoundProgrammersMessage}"/>
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    
                    <!-- Scan Wired / Wireless and Cancel -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                        <Button Click="SearchWiredProgrammers_Click"
                                Margin="0,0,8,0"
                                ToolTip="Scan for wired programmers (e.g. HI-PRO)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="Scan Wired"/>
                            </Button.Content>
                        </Button>
                        <Button Click="SearchWirelessProgrammers_Click"
                                Margin="0,0,8,0"
                                ToolTip="Scan for wireless programmers (e.g. NOAHlink, RSL10)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="Scan Wireless"/>
                            </Button.Content>
                        </Button>
                        <!-- Cancel Button -->
                        <Button Click="CancelSearch_Click"
                                IsEnabled="{Binding CanCancelSearch}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Background" Value="#EF4444"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#DC2626"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                    
                    <!-- Timeout Message -->
                    <TextBlock Grid.Column="2"
                               Grid.Row="1"
                               Text="{Binding TimeoutMessage}"
                               FontSize="12"
                               Foreground="#92400E"
                               Margin="16,4,0,0"
                               HorizontalAlignment="Left">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            
            <!-- Step 2: Select Programmer -->
            <Border Style="{StaticResource StepCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Step 2: Select Programmer" 
                               Style="{StaticResource Heading3Style}"
                               Margin="0,0,0,8"/>
                    
                    <!-- Programmers List -->
                    <ItemsControl ItemsSource="{Binding Programmers}" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProgrammerItemStyle}"
                                        Margin="0,0,0,12"
                                        MouseLeftButtonDown="ProgrammerItem_MouseLeftButtonDown"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon -->
                                        <Border Grid.Column="0"
                                                Width="64" Height="64"
                                                Background="{StaticResource Gray100Brush}"
                                                CornerRadius="8"
                                                Margin="0,0,16,0">
                                            <TextBlock Text="🔌" 
                                                       FontSize="32"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="S/N: " 
                                                           Style="{StaticResource CaptionStyle}"/>
                                                <TextBlock Text="{Binding SerialNumber}" 
                                                           Style="{StaticResource CaptionStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="Firmware: " 
                                                           Style="{StaticResource CaptionStyle}"/>
                                                <TextBlock Text="{Binding Firmware}" 
                                                           Style="{StaticResource CaptionStyle}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Port}" 
                                                       Style="{StaticResource CaptionStyle}"/>
                                        </StackPanel>
                                        
                                        <!-- Radio Button -->
                                        <Ellipse Grid.Column="2"
                                                 Width="24" Height="24"
                                                 Stroke="{StaticResource Gray300Brush}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                                            <Setter Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- No Programmers Message -->
                    <StackPanel HorizontalAlignment="Center"
                                Margin="0,32,0,32">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProgrammers}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="64" Height="64"
                                Background="{StaticResource Gray100Brush}"
                                CornerRadius="8"
                                Margin="0,0,0,16"
                                HorizontalAlignment="Center">
                            <TextBlock Text="🔌" 
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Gray400Brush}"/>
                        </Border>
                        <TextBlock Text="No Programmers Scanned" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Click 'Scan for Programmers' to detect devices"
                                   Style="{StaticResource CaptionStyle}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Discover & Connect Hearing Aids (merged Step 3 + 4 + Connect) -->
            <Border Style="{StaticResource StepCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Discover &amp; Connect Hearing Aids" 
                               Style="{StaticResource Heading3Style}"
                               Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- LEFT COLUMN: Discovery controls + status -->
                        <StackPanel Grid.Column="0">
                            <Button Click="DiscoverDevices_Click"
                                    IsEnabled="{Binding CanDiscover}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="📡" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Scan for Hearing Aids"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                                            <Setter Property="Text" Value="Scanning…"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Click="DiscoverDevices_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="Rescan"/>
                                </Button>
                                <Button Click="StopDiscovery_Click"
                                        Padding="8,4">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Stop"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource CaptionStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"/>
                            <ProgressBar Maximum="100"
                                         Height="8"
                                         Margin="0,12,0,0"
                                         IsIndeterminate="True">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource ProgressBarStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                        </StackPanel>
                        
                        <!-- RIGHT COLUMN: Detected devices list or empty state -->
                        <Border Grid.Column="2"
                                Background="{StaticResource Gray50Brush}"
                                CornerRadius="8"
                                Padding="16"
                                MinHeight="180">
                            <Grid>
                                <!-- Empty state -->
                                <StackPanel HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDevices}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="🔌"
                                               FontSize="32"
                                               Foreground="{StaticResource Gray400Brush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="No devices detected yet."
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Place hearing aids on HI-PRO and click Scan."
                                               Style="{StaticResource CaptionStyle}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                </StackPanel>
                                <!-- Devices list (only detected devices) -->
                                <ItemsControl ItemsSource="{Binding Devices}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDevices}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="12"
                                                Background="{StaticResource WhiteBrush}"
                                                BorderBrush="{StaticResource Gray200Brush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MouseLeftButtonDown="DeviceCard_MouseLeftButtonDown">
                                            <StackPanel>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          FontSize="14"
                                                          FontWeight="SemiBold"
                                                          Margin="0,0,0,8"
                                                          Checked="DeviceCheckBox_Checked"
                                                          Unchecked="DeviceCheckBox_Checked">
                                                    <CheckBox.Content>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="{StaticResource PrimaryBrush}"
                                                                    CornerRadius="4"
                                                                    Padding="4,2"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Side}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource WhiteBrush}"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                            <TextBlock Text="Select" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </CheckBox.Content>
                                                </CheckBox>
                                                <TextBlock Text="{Binding Model}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SerialNumber, StringFormat='Serial: {0}'}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Firmware, StringFormat='Firmware: {0}'}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                                    <TextBlock Text="🔋" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <ProgressBar Value="{Binding BatteryLevel}"
                                                                 Maximum="100"
                                                                 Height="4"
                                                                 Width="80"
                                                                 Style="{StaticResource BatteryProgressBarStyle}"/>
                                                    <TextBlock Text="{Binding BatteryLevel, StringFormat='{}{0}%'}"
                                                               Style="{StaticResource CaptionStyle}"
                                                               Margin="4,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- Footer: Connect to Selected -->
                    <Button Click="ConnectDevices_Click"
                            IsEnabled="{Binding CanConnect}"
                            HorizontalAlignment="Stretch"
                            Margin="0,20,0,0"
                            Padding="24,12">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SuccessButtonStyle}"/>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="🔗"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                    <Setter Property="Text" Value="⏳"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Connect to Selected"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                    <Setter Property="Text" Value="Connecting…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    
                    <!-- Connecting progress -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar Value="{Binding ConnectionProgress}"
                                     Maximum="100"
                                     Height="6"
                                     Style="{StaticResource ProgressBarStyle}"/>
                        <TextBlock Text="{Binding ConnectionStatusMessage}"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <!-- Success banner inside same card -->
                    <Border Style="{StaticResource StatusBannerSuccessStyle}"
                            Margin="0,16,0,0"
                            Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="✓" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Successfully connected to devices!"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="All devices are connected and ready for fitting"
                                       Style="{StaticResource CaptionStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
