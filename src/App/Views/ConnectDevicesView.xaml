<UserControl x:Class="Ul8ziz.FittingApp.App.Views.ConnectDevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,16,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Title + Status bar row with Scan Wired / Scan Wireless / Help / Cancel -->
            <Border Grid.Row="0" Margin="0,0,0,20" Background="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource Gray200Brush}" BorderThickness="1" CornerRadius="8" Padding="20,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Connect Devices"
                           Style="{StaticResource Heading1Style}"
                           Margin="0,0,0,12"/>

                <!-- Status bar: green when programmer found, with message; Scan Wired / Scan Wireless / Help on right -->
                <Border Grid.Row="1" Padding="14,10" CornerRadius="6"
                        BorderThickness="1" BorderBrush="{StaticResource Gray200Brush}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource Gray50Brush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                    <Setter Property="BorderBrush" Value="#FECACA"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                    <Setter Property="Background" Value="#D1FAE5"/>
                                    <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                    <Setter Property="Background" Value="#FEF3C7"/>
                                    <Setter Property="BorderBrush" Value="#FCD34D"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Icon -->
                        <Ellipse Grid.Column="0" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Gray400Brush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Fill" Value="#F59E0B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                            <Setter Property="Fill" Value="#EF4444"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Column="1" Text="{Binding StatusBarText}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanFoundNothing}" Value="True">
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Foreground" Value="#92400E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Click="SearchWiredProgrammers_Click" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Content>
                                    <TextBlock Text="Scan Wired"/>
                                </Button.Content>
                            </Button>
                            <Button Click="SearchWirelessProgrammers_Click" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Content>
                                    <TextBlock Text="Scan Wireless"/>
                                </Button.Content>
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                                    ToolTip="Help">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Help" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ⓘ" FontSize="12" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Click="CancelSearch_Click" IsEnabled="{Binding CanCancelSearch}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button.Content>
                                    <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                </Grid>
            </Border>

            <!-- Two-column: Setup | Discover & Connect -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="320"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*" MinWidth="360"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Setup -->
                <Border Grid.Column="0" Background="{StaticResource WhiteBrush}"
                        BorderBrush="{StaticResource Gray200Brush}" BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="Setup" Style="{StaticResource Heading3Style}" Margin="0,0,0,16"/>
                    <TextBlock Text="Step 1: Product Library" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableLibraries}"
                              SelectedItem="{Binding SelectedLibrary}"
                              DisplayMemberPath="FileName"
                              Height="40" FontSize="14" Padding="8,0"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,20">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Text="Step 2: Programmer" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Programmers}" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        MouseLeftButtonDown="ProgrammerItem_MouseLeftButtonDown"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource ProgrammerItemStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Background" Value="{StaticResource SelectedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48"
                                                Background="{StaticResource Gray100Brush}"
                                                CornerRadius="6" Margin="0,0,12,0">
                                            <TextBlock Text="🔌" FontSize="24"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="S/N: "/>
                                                <Run Text="{Binding SerialNumber}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Firmware, StringFormat='Firmware: {0}'}"
                                                       Style="{StaticResource CaptionStyle}" Margin="0,0,0,0"/>
                                            <TextBlock Text="{Binding Port}" Style="{StaticResource CaptionStyle}"/>
                                        </StackPanel>
                                        <Ellipse Grid.Column="2" Width="20" Height="20"
                                                 Stroke="{StaticResource Gray300Brush}"
                                                 StrokeThickness="2" Fill="Transparent"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                                            <Setter Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel HorizontalAlignment="Center" Margin="0,24,0,24">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProgrammers}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="No programmers scanned. Click Scan Wired or Scan Wireless."
                                   Style="{StaticResource CaptionStyle}" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Expander Header="Advanced" IsExpanded="False" Margin="0,12,0,0">
                        <Border Padding="12,8" Background="{StaticResource Gray50Brush}" CornerRadius="4" Margin="0,4,0,0">
                            <TextBlock Text="Additional programmer options (placeholder)." Style="{StaticResource CaptionStyle}"/>
                        </Border>
                    </Expander>
                    </StackPanel>
                </Border>

                <!-- Right: Discover & Connect -->
                <Border Grid.Column="2" Background="{StaticResource WhiteBrush}"
                        BorderBrush="{StaticResource Gray200Brush}" BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel>
                    <TextBlock Text="Discover &amp; Connect" Style="{StaticResource Heading3Style}" Margin="0,0,0,16"/>
                    <Button Click="DiscoverDevices_Click" IsEnabled="{Binding CanDiscover}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="20,12" Margin="0,0,0,16">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Scan for Hearing Aids"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                                <Setter Property="Text" Value="Scanning…"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDevices}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Click="DiscoverDevices_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="Rescan"/>
                        </Button>
                        <Button Click="StopDiscovery_Click" Padding="8,4">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDiscovering}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Stop"/>
                        </Button>
                    </StackPanel>
                    <Border Margin="0,0,0,12" Padding="16,12" Background="{StaticResource Gray50Brush}"
                            BorderBrush="{StaticResource Gray200Brush}" BorderThickness="1" CornerRadius="8"
                            Visibility="{Binding IsDiscovering, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionStyle}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <ProgressBar Style="{StaticResource LoadingIndeterminateProgressBarStyle}" HorizontalAlignment="Left" Height="4"/>
                        </StackPanel>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Padding="14"
                                        Background="{StaticResource WhiteBrush}"
                                        BorderBrush="{StaticResource Gray200Brush}"
                                        BorderThickness="1" CornerRadius="8"
                                        MouseLeftButtonDown="DeviceCard_MouseLeftButtonDown">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding IsSelected}" FontSize="14" FontWeight="SemiBold"
                                                  Margin="0,0,0,8"
                                                  Checked="DeviceCheckBox_Checked" Unchecked="DeviceCheckBox_Checked">
                                            <CheckBox.Content>
                                                <TextBlock Text="{Binding Side}" VerticalAlignment="Center"/>
                                            </CheckBox.Content>
                                        </CheckBox>
                                        <TextBlock Text="{Binding SerialNumber, StringFormat='Serial {0}'}" Style="{StaticResource CaptionStyle}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Firmware, StringFormat='Firmware: {0}'}" Style="{StaticResource CaptionStyle}" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="🔋" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding BatteryLevel}" Maximum="100" Height="6"
                                                        Style="{StaticResource BatteryProgressBarStyle}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding BatteryLevel, StringFormat='{}{0}%'}"
                                                       Style="{StaticResource CaptionStyle}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Click="DiscoverDevices_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="6,4" Margin="0,0,6,0">
                                                <TextBlock Text="Rescan"/>
                                            </Button>
                                            <Button Click="StopDiscovery_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="6,4">
                                                <TextBlock Text="Stop"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Margin="0,24,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDevices}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="No devices detected yet. Place hearing aids on HI-PRO and click Scan for Hearing Aids."
                                   Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer area: action bar, then optional progress/success (stacked cleanly) -->
            <StackPanel Grid.Row="3" Margin="0,24,0,0">
                <!-- Footer: single box — Selected + Connect when not connected, success message when connected -->
                <Border Padding="20,16,20,16"
                        BorderBrush="{StaticResource Gray200Brush}" BorderThickness="1" CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="#D1FAE5"/>
                                    <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Not connected: Selected summary + Connect button -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding SelectedDevicesSummary}"
                                       Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Click="ConnectDevices_Click"
                                    IsEnabled="{Binding CanConnect}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Padding="28,12">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Connect"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                            <Setter Property="Text" Value="Connecting…"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>
                        <!-- Connected: success message -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="✓" FontSize="16" Foreground="#047857" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Successfully connected to devices!" FontSize="14" FontWeight="SemiBold" Foreground="#065F46" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="All devices are connected and ready for fitting" Style="{StaticResource CaptionStyle}" Foreground="#047857"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Connecting progress (below footer when connecting) -->
                <Border Margin="0,12,0,0" Padding="16,12"
                        Background="{StaticResource Gray50Brush}"
                        BorderBrush="{StaticResource Gray200Brush}"
                        BorderThickness="1" CornerRadius="8"
                        Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <ProgressBar Value="{Binding ConnectionProgress}" Maximum="100" Height="6"
                                     Style="{StaticResource ProgressBarStyle}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ConnectionStatusMessage}" Style="{StaticResource CaptionStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
