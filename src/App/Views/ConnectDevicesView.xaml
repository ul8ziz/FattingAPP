<UserControl x:Class="Ul8ziz.FittingApp.App.Views.ConnectDevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24">
            
            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Connect Devices" 
                           Style="{StaticResource Heading1Style}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Select programmer and hearing aid devices to connect" 
                           Style="{StaticResource CaptionStyle}"/>
            </StackPanel>
            
            <!-- Status Banner: No Programmer Selected / Programmer Selected / Connected -->
            <Border Style="{StaticResource StatusBannerInfoStyle}"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Width="24" Height="24"
                            Background="#3B82F6"
                            CornerRadius="12"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                        <Setter Property="Background" Value="#F59E0B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="!"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WhiteBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="!"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Text" Value="✓"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    
                    <!-- Message -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1E40AF"
                                   Margin="0,0,0,2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="No Programmer Selected"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Text" Value="Searching for Programmers..."/>
                                            <Setter Property="Foreground" Value="#92400E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Text" Value="Programmer Selected"/>
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontSize="13"
                                   Foreground="#1E40AF"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Scan and select a programmer to begin"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Text" Value="Please wait while we search for connected programmers"/>
                                            <Setter Property="Foreground" Value="#92400E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasFoundProgrammers}" Value="True">
                                            <Setter Property="Text" Value="{Binding SelectedProgrammerName, StringFormat='{}{0} - Select hearing aids to connect'}"/>
                                            <Setter Property="Foreground" Value="#065F46"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    
                    <!-- Scan Button and Cancel Button -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                        <Button Click="SearchProgrammers_Click"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Loading Spinner -->
                                    <Grid Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse Width="16" Height="16" 
                                                Stroke="#0D6EFD" 
                                                StrokeThickness="2"
                                                StrokeDashArray="3 2"
                                                Opacity="0.3"/>
                                        <Ellipse Width="16" Height="16" 
                                                Stroke="#0D6EFD" 
                                                StrokeThickness="2"
                                                StrokeDashArray="3 2"
                                                StrokeDashOffset="6">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform CenterX="8" CenterY="8"/>
                                            </Ellipse.RenderTransform>
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="SpinnerRotationStoryboard">
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                         From="0" To="360" Duration="0:0:1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="SpinnerRotationStoryboard"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock Text="Scan for Programmers" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        
                        <!-- Cancel Button -->
                        <Button Click="CancelSearch_Click"
                                IsEnabled="{Binding CanCancelSearch}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Background" Value="#EF4444"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="12,6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#DC2626"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                    
                    <!-- Timeout Message -->
                    <TextBlock Grid.Column="2"
                               Grid.Row="1"
                               Text="{Binding TimeoutMessage}"
                               FontSize="12"
                               Foreground="#92400E"
                               Margin="16,4,0,0"
                               HorizontalAlignment="Left">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            
            <!-- Step 2: Select Programmer -->
            <Border Style="{StaticResource StepCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Step 2: Select Programmer" 
                               Style="{StaticResource Heading3Style}"
                               Margin="0,0,0,8"/>
                    
                    <!-- Programmers List -->
                    <ItemsControl ItemsSource="{Binding Programmers}" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProgrammerItemStyle}"
                                        Margin="0,0,0,12"
                                        MouseLeftButtonDown="ProgrammerItem_MouseLeftButtonDown"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icon -->
                                        <Border Grid.Column="0"
                                                Width="64" Height="64"
                                                Background="{StaticResource Gray100Brush}"
                                                CornerRadius="8"
                                                Margin="0,0,16,0">
                                            <TextBlock Text="🔌" 
                                                       FontSize="32"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="S/N: " 
                                                           Style="{StaticResource CaptionStyle}"/>
                                                <TextBlock Text="{Binding SerialNumber}" 
                                                           Style="{StaticResource CaptionStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="Firmware: " 
                                                           Style="{StaticResource CaptionStyle}"/>
                                                <TextBlock Text="{Binding Firmware}" 
                                                           Style="{StaticResource CaptionStyle}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Port}" 
                                                       Style="{StaticResource CaptionStyle}"/>
                                        </StackPanel>
                                        
                                        <!-- Radio Button -->
                                        <Ellipse Grid.Column="2"
                                                 Width="24" Height="24"
                                                 Stroke="{StaticResource Gray300Brush}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                                            <Setter Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- No Programmers Message -->
                    <StackPanel HorizontalAlignment="Center"
                                Margin="0,32,0,32">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProgrammers}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="64" Height="64"
                                Background="{StaticResource Gray100Brush}"
                                CornerRadius="8"
                                Margin="0,0,0,16"
                                HorizontalAlignment="Center">
                            <TextBlock Text="🔌" 
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Gray400Brush}"/>
                        </Border>
                        <TextBlock Text="No Programmers Scanned" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Click 'Scan for Programmers' to detect devices"
                                   Style="{StaticResource CaptionStyle}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Step 3: Discover Hearing Aids -->
            <Border Style="{StaticResource StepCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Step 3: Discover Hearing Aids" 
                               Style="{StaticResource Heading3Style}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Place hearing aids near the programmer" 
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,16"/>
                    
                    <Button Click="DiscoverDevices_Click"
                            IsEnabled="{Binding CanDiscover}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}"/>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📡" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Discover Devices" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    
                    <!-- Progress Bar -->
                    <ProgressBar Value="{Binding DiscoveryProgress}"
                                 Maximum="100"
                                 Height="8"
                                 Margin="0,16,0,0"
                                 Visibility="{Binding IsDiscovering, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Style="{StaticResource ProgressBarStyle}">
                        <ProgressBar.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ProgressBar.Triggers>
                    </ProgressBar>
                    
                    <!-- Discovering Status -->
                    <TextBlock Text="Searching for devices..."
                               Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="{Binding IsDiscovering, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    
                    <!-- Found Status -->
                    <Border Style="{StaticResource StatusBannerSuccessStyle}"
                            Margin="0,16,0,0"
                            Visibility="{Binding HasFoundDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FoundDevicesMessage}" 
                                       FontSize="14"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Step 4: Select Devices -->
            <Border Style="{StaticResource StepCardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Step 4: Select Devices" 
                                   Style="{StaticResource Heading3Style}"
                                   Grid.Column="0"/>
                        <TextBlock Text="{Binding SelectedDevicesCount, StringFormat='{}{0} device(s) selected'}"
                                   Style="{StaticResource CaptionStyle}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="Medium"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Devices Grid -->
                    <Grid Visibility="{Binding HasDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Ear Device -->
                        <Border Grid.Column="0" 
                                Style="{StaticResource DeviceCardLeftStyle}"
                                MouseLeftButtonDown="DeviceCard_MouseLeftButtonDown"
                                DataContext="{Binding LeftDevice}">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsSelected}"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"
                                          Checked="DeviceCheckBox_Checked"
                                          Unchecked="DeviceCheckBox_Checked">
                                    <CheckBox.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🦻" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Left Ear" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                                
                                <TextBlock Text="{Binding Model}" 
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SerialNumber, StringFormat='Serial Number: {0}'}" 
                                           Style="{StaticResource CaptionStyle}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Firmware, StringFormat='Firmware: {0}'}" 
                                           Style="{StaticResource CaptionStyle}"
                                           Margin="0,0,0,12"/>
                                
                                <!-- Battery Indicator -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="🔋" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <ProgressBar Value="{Binding BatteryLevel}"
                                                 Maximum="100"
                                                 Height="6"
                                                 Width="200"
                                                 Style="{StaticResource BatteryProgressBarStyle}"/>
                                    <TextBlock Text="{Binding BatteryLevel, StringFormat='{}{0}%'}"
                                               Style="{StaticResource CaptionStyle}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Right Ear Device -->
                        <Border Grid.Column="2" 
                                Style="{StaticResource DeviceCardRightStyle}"
                                MouseLeftButtonDown="DeviceCard_MouseLeftButtonDown"
                                DataContext="{Binding RightDevice}">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsSelected}"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"
                                          Checked="DeviceCheckBox_Checked"
                                          Unchecked="DeviceCheckBox_Checked">
                                    <CheckBox.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🦻" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Right Ear" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                                
                                <TextBlock Text="{Binding Model}" 
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SerialNumber, StringFormat='Serial Number: {0}'}" 
                                           Style="{StaticResource CaptionStyle}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Firmware, StringFormat='Firmware: {0}'}" 
                                           Style="{StaticResource CaptionStyle}"
                                           Margin="0,0,0,12"/>
                                
                                <!-- Battery Indicator -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="🔋" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <ProgressBar Value="{Binding BatteryLevel}"
                                                 Maximum="100"
                                                 Height="6"
                                                 Width="200"
                                                 Style="{StaticResource BatteryProgressBarStyle}"/>
                                    <TextBlock Text="{Binding BatteryLevel, StringFormat='{}{0}%'}"
                                               Style="{StaticResource CaptionStyle}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- No Devices Message -->
                    <TextBlock Text="No devices found. Click 'Discover Devices' to search for hearing aids."
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDevices}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <!-- Step 5: Connect -->
            <StackPanel Margin="0,0,0,24">
                <Button Click="ConnectDevices_Click"
                        IsEnabled="{Binding CanConnect}"
                        HorizontalAlignment="Stretch"
                        Padding="24,12">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SuccessButtonStyle}"/>
                    </Button.Style>
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔗" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Connect to Selected Devices" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                
                <!-- Connecting Status -->
                <StackPanel Margin="0,16,0,0"
                            Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    <ProgressBar Value="{Binding ConnectionProgress}"
                                 Maximum="100"
                                 Height="8"
                                 Style="{StaticResource ProgressBarStyle}"/>
                    <TextBlock Text="{Binding ConnectionStatusMessage}"
                               Style="{StaticResource CaptionStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
                
                <!-- Connected Success -->
                <Border Style="{StaticResource StatusBannerSuccessStyle}"
                        Margin="0,16,0,0"
                        Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="✓" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Successfully connected to devices!" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="All devices are connected and ready for fitting" 
                                   Style="{StaticResource CaptionStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
