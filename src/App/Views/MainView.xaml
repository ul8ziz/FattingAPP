<UserControl x:Class="Ul8ziz.FittingApp.App.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Styles.xaml"/>
                <ResourceDictionary Source="../Styles/SidebarStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Session end toast banner (single line, auto-hides) -->
        <Border Grid.Row="0" Background="{StaticResource SuccessBrush}" Padding="12,8" Margin="0"
                Visibility="{Binding SessionEndBannerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding SessionEndBannerText}" Foreground="{StaticResource WhiteBrush}" FontSize="13" HorizontalAlignment="Center"/>
        </Border>

        <!-- TopBar -->
        <Border Grid.Row="1" Style="{StaticResource TopBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title Section -->
                <Grid Grid.Column="0" Margin="0,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <Border Grid.Column="0"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" Height="64" Width="193">
                        <Image Source="pack://application:,,,/Resources/Images/AppLogo.png"
                               Width="156"
                               Height="56"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Title Section -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Fitting System" 
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" Width="194"/>
                    </StackPanel>
                </Grid>

                <!-- Status Indicators Section -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0">

                    <!-- Unsaved Changes Warning -->
                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeAmberStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" 
                                     Fill="#F59E0B" 
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Unsaved Changes" 
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="#92400E"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Active Session Indicator -->
                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeGreenStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveSession}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Active Session" 
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="#065F46"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Fitting in Progress" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#047857"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Ellipse Grid.Column="1" 
                                     Width="12" 
                                     Height="12" 
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.3" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <!-- End Session Button -->
                    <Button Grid.Column="1"
                            Margin="0,0,8,0"
                            Command="{Binding EndSessionCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveSession}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="→" FontSize="14" Margin="0,0,4,0"/>
                                <TextBlock Text="End Session"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- Connection Status (driven by AppSessionState) -->
                <Border Grid.Column="2" 
                        Style="{StaticResource StatusBadgeGrayStyle}"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Margin="0,0,12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Connection Status" 
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ConnectionStatusText}" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ConnectedDeviceDisplayName}" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnectedDeviceNameVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Ellipse Grid.Column="1" 
                                     Width="12" 
                                     Height="12" 
                                     Fill="{Binding ConnectionStatusBrush}"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Style="{StaticResource SidebarStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation Header -->
                    <StackPanel Grid.Row="0" Margin="16,20,16,0">
                        <TextBlock Text="Navigation"
                                   FontFamily="Segoe UI"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Fitting Workflow"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                        <Border Height="1" Background="{StaticResource Gray200Brush}" Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- Navigation Items -->
                    <ScrollViewer Grid.Row="1"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="12,16,12,0">

                            <!-- Connect Devices (disabled while Configure Device is running) -->
                            <Button Style="{StaticResource SidebarNavButtonConnectStyle}"
                                    Click="ConnectDevicesButton_Click"
                                    IsEnabled="{Binding CanNavigateToConnect}"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Connect Devices" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Quick Fitting: second item after Connect — abbreviated controls (same session as Fitting) -->
                            <Button Style="{StaticResource SidebarNavButtonQuickFittingStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="QuickFitting"
                                    IsEnabled="{Binding IsNavigationEnabled}"
                                    Margin="0,0,0,4"
                                    ToolTip="Fast access to FBC, noise reduction, and memory controls">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Quick Fitting" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Audiogram — requires a connected hearing aid (same guard as Fitting) -->
                            <Button Style="{StaticResource SidebarNavButtonAudiogramStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Audiogram"
                                    IsEnabled="{Binding IsNavigationEnabled}"
                                    Margin="0,0,0,4"
                                    ToolTip="Connect a hearing aid to enable Audiogram">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Audiogram" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Fitting -->
                            <Button Style="{StaticResource SidebarNavButtonFittingStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Fitting"
                                    IsEnabled="{Binding IsNavigationEnabled}"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Fitting" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Session Summary (disabled until implemented) -->
                            <Button Style="{StaticResource SidebarNavButtonSessionSummaryStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="SessionSummary"
                                    IsEnabled="False"
                                    Margin="0,0,0,4"
                                    ToolTip="Not yet implemented">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Session Summary" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- System Info (static text only) -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource Gray200Brush}"
                            BorderThickness="0,1,0,0"
                            Padding="16,16">
                        <StackPanel>
                            <TextBlock Text="Software Info"
                                       FontFamily="Segoe UI"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Version 1.0.0"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       Foreground="#4B5563"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Developed by ul8ziz"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       Foreground="#4B5563"
                                       Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentPresenter Grid.Column="1" 
                            Content="{Binding CurrentView}"
                            Margin="0"/>
        </Grid>
    </Grid>
</UserControl>
