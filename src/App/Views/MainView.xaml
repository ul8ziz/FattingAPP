<UserControl x:Class="Ul8ziz.FittingApp.App.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Border Grid.Row="0" Style="{StaticResource TopBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title Section -->
                <Grid Grid.Column="0" Margin="0,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <Border Grid.Column="0"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" Height="64" Width="193">
                        <Image Source="pack://application:,,,/Resources/Images/AppLogo.png"
                               Width="156"
                               Height="56"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Title Section -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Fitting System" 
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" Width="194"/>
                    </StackPanel>
                </Grid>

                <!-- Status Indicators Section -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0">

                    <!-- Unsaved Changes Warning -->
                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeAmberStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" 
                                     Fill="#F59E0B" 
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Unsaved Changes" 
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="#92400E"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Active Session Indicator -->
                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeGreenStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveSession}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Active Session" 
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="#065F46"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Fitting in Progress" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#047857"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Ellipse Grid.Column="1" 
                                     Width="12" 
                                     Height="12" 
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.3" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                    </Border>

                    <!-- End Session Button -->
                    <Button Grid.Column="1"
                            Margin="0,0,8,0"
                            Command="{Binding EndSessionCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveSession}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="→" FontSize="14" Margin="0,0,4,0"/>
                                <TextBlock Text="End Session"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- Connection Status -->
                <Border Grid.Column="2" 
                        Style="{StaticResource StatusBadgeGrayStyle}"
                        Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Connection Status" 
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding ConnectionStatusText}" 
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Ellipse Grid.Column="1" 
                                 Width="12" 
                                 Height="12" 
                                 Fill="{Binding ConnectionStatusBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- User Info -->
                <Grid Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" 
                               Margin="0,0,12,0"
                               VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" 
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding UserRole}" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1" 
                            Width="40" 
                            Height="40" 
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="20">
                        <TextBlock Text="U" 
                                   FontSize="20" 
                                   FontWeight="Medium"
                                   Foreground="{StaticResource WhiteBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Style="{StaticResource SidebarStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation Header -->

                    <!-- Navigation Items -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16,16,16,0">

                            <!-- Connect Devices -->
                            <Button Style="{StaticResource NavigationButtonStyle}"
                                    Click="ConnectDevicesButton_Click"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔌" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Connect Devices" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Patient Management -->
                            <Button Style="{StaticResource NavigationButtonStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="PatientManagement"
                                    IsEnabled="{Binding IsDeviceReady}"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👥" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Patient Management" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Audiogram -->
                            <Button Style="{StaticResource NavigationButtonStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Audiogram"
                                    IsEnabled="{Binding IsDeviceReady}"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Audiogram" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Fitting -->
                            <Button Style="{StaticResource NavigationButtonStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Fitting"
                                    IsEnabled="{Binding IsDeviceReady}"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Fitting" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <!-- Session Summary -->
                            <Button Style="{StaticResource NavigationButtonStyle}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="SessionSummary"
                                    IsEnabled="{Binding IsDeviceReady}"
                                    Margin="0,0,0,4">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📄" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Session Summary" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- System Info Footer -->
                    <Border Grid.Row="2" 
                            BorderBrush="{StaticResource Gray200Brush}"
                            BorderThickness="0,1,0,0"
                            Padding="16,16">
                        <StackPanel>
                            <TextBlock Text="System Info" 
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Version 1.0.0" 
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentPresenter Grid.Column="1" 
                            Content="{Binding CurrentView}"
                            Margin="0"/>
        </Grid>
    </Grid>
</UserControl>
