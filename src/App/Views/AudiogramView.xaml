<UserControl x:Class="Ul8ziz.FittingApp.App.Views.AudiogramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:Ul8ziz.FittingApp.App.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Graphs panel (left) -->
        <views:GraphsPanelView Grid.Column="0" Width="320" Margin="0,0,16,0"
                               DataContext="{Binding GraphsPanelViewModel}"/>

        <!-- Main area: Audiogram placeholder + note -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="24">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Audiogram" Style="{StaticResource Heading1Style}" Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" MaxWidth="400" Margin="0,0,0,16">
                    <Run Text="Graphs (Frequency Gain, I/O) are in the left panel. Use Refresh to update from the current session cache."/>
                </TextBlock>
                <Button Command="{Binding RefreshFromSessionCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="14,8" HorizontalAlignment="Left">
                    <TextBlock Text="Refresh graphs from session" VerticalAlignment="Center" FontSize="13"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
