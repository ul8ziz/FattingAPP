<UserControl x:Class="Ul8ziz.FittingApp.App.Views.Controls.QuickFittingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Ul8ziz.FittingApp.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="480">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Styles/Styles.xaml"/>
                <ResourceDictionary Source="../../Styles/ParameterFieldStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <vm:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <vm:ObjectToBoolConverter x:Key="ObjectToBoolConverter"/>
            <vm:ObjectToDoubleConverter x:Key="ObjectToDoubleConverter"/>
            <vm:DoubleNaNToFallbackConverter x:Key="DoubleNaNToFallbackConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel Margin="16,4,16,16">

            <!-- ===== FBC Section ===== -->
            <TextBlock Text="Feedback Cancellation (FBC)" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding FbcEnable.DisplayName, FallbackValue='FBC Enable'}"
                               Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Style="{StaticResource ParameterToggleSwitchStyle}"
                                  IsChecked="{Binding FbcEnable.Value, Mode=TwoWay, Converter={StaticResource ObjectToBoolConverter}}"
                                  IsEnabled="{Binding FbcEnable.ReadOnly, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                        <TextBlock Text="{Binding FbcEnable.BoolLabel, FallbackValue=''}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource Gray600Brush}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding FbcGainMgmtEnable.DisplayName, FallbackValue='FBC Gain Management Enable'}"
                               Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Style="{StaticResource ParameterToggleSwitchStyle}"
                                  IsChecked="{Binding FbcGainMgmtEnable.Value, Mode=TwoWay, Converter={StaticResource ObjectToBoolConverter}}"
                                  IsEnabled="{Binding FbcGainMgmtEnable.ReadOnly, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                        <TextBlock Text="{Binding FbcGainMgmtEnable.BoolLabel, FallbackValue=''}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource Gray600Brush}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding FbcGainMgmtLimit.DisplayName, FallbackValue='FBC Gain Management Limit'}"
                               Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Style="{StaticResource ParameterSliderStyle}"
                                Minimum="{Binding FbcGainMgmtLimit.Min, Converter={StaticResource DoubleNaNToFallbackConverter}, ConverterParameter=0}"
                                Maximum="{Binding FbcGainMgmtLimit.Max, Converter={StaticResource DoubleNaNToFallbackConverter}, ConverterParameter=100}"
                                Value="{Binding FbcGainMgmtLimit.Value, Mode=TwoWay, Converter={StaticResource ObjectToDoubleConverter}}"
                                TickFrequency="{Binding FbcGainMgmtLimit.SafeTickFrequency}"
                                IsSnapToTickEnabled="{Binding FbcGainMgmtLimit.HasStep}"
                                IsEnabled="{Binding FbcGainMgmtLimit.ReadOnly, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                        <TextBlock Grid.Column="1" Text="{Binding FbcGainMgmtLimit.FormattedValue, Mode=OneWay, FallbackValue='—'}"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="56"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Noise Reduction Section ===== -->
            <TextBlock Text="Noise Reduction" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,16,0,10"/>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding NrEnable.DisplayName, FallbackValue='Noise Reduction Enable'}"
                               Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Style="{StaticResource ParameterToggleSwitchStyle}"
                                  IsChecked="{Binding NrEnable.Value, Mode=TwoWay, Converter={StaticResource ObjectToBoolConverter}}"
                                  IsEnabled="{Binding NrEnable.ReadOnly, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                        <TextBlock Text="{Binding NrEnable.BoolLabel, FallbackValue=''}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource Gray600Brush}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="Noise Reduction Depth (all channels)" Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <TextBlock Text="Adjusts all NR channel depths simultaneously" FontSize="11"
                               Foreground="{StaticResource Gray500Brush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Style="{StaticResource ParameterSliderStyle}"
                                Minimum="{Binding NrSliderMin}"
                                Maximum="{Binding NrSliderMax}"
                                Value="{Binding NrMasterDepth, Mode=TwoWay}"
                                TickFrequency="{Binding NrSliderStep}"
                                IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" Text="{Binding NrMasterDepth, StringFormat='{}{0:F0}'}"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Memory / MMI Section ===== -->
            <TextBlock Text="Memory &amp; Controls" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,16,0,10"/>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding MmiEnable.DisplayName, FallbackValue='MMI Enable'}"
                               Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Style="{StaticResource ParameterToggleSwitchStyle}"
                                  IsChecked="{Binding MmiEnable.Value, Mode=TwoWay, Converter={StaticResource ObjectToBoolConverter}}"
                                  IsEnabled="{Binding MmiEnable.ReadOnly, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                        <TextBlock Text="{Binding MmiEnable.BoolLabel, FallbackValue=''}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource Gray600Brush}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ParameterFieldCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding PowerOnDelay.DisplayName, FallbackValue='Power On Delay'}"
                               Style="{StaticResource ParameterFieldTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Style="{StaticResource ParameterSliderStyle}"
                                Minimum="{Binding PowerOnDelay.Min, Converter={StaticResource DoubleNaNToFallbackConverter}, ConverterParameter=0}"
                                Maximum="{Binding PowerOnDelay.Max, Converter={StaticResource DoubleNaNToFallbackConverter}, ConverterParameter=100}"
                                Value="{Binding PowerOnDelay.Value, Mode=TwoWay, Converter={StaticResource ObjectToDoubleConverter}}"
                                TickFrequency="{Binding PowerOnDelay.SafeTickFrequency}"
                                IsSnapToTickEnabled="{Binding PowerOnDelay.HasStep}"
                                IsEnabled="{Binding PowerOnDelay.ReadOnly, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PowerOnDelay.FormattedValue, Mode=OneWay, FallbackValue='—'}"
                                   FontSize="13" Foreground="{StaticResource Gray700Brush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" Width="56"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
