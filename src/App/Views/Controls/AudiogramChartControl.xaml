<UserControl x:Class="Ul8ziz.FittingApp.App.Views.Controls.AudiogramChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="200" MinWidth="260"
             Background="Transparent">
    <Grid>
        <!-- Chart canvas — grid, labels, and data points drawn here in code-behind -->
        <Canvas x:Name="ChartCanvas" Background="White"
                ClipToBounds="True"
                SizeChanged="ChartCanvas_SizeChanged"/>

        <!-- Transparent click overlay — sits on top of canvas to capture mouse -->
        <Rectangle x:Name="ClickOverlay"
                   Fill="Transparent"
                   Cursor="Cross"
                   MouseLeftButtonDown="ClickOverlay_MouseLeftButtonDown"/>
    </Grid>
</UserControl>
